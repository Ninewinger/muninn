# Environment configuration template
# Copy to .env and fill in your values
#
# Do NOT commit .env to the repo. This template is the safe reference.

# Embedding model
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSIONS=384

# LLM for dreaming/consolidation + curiosity (any OpenAI-compatible API)
# PRIMARY: Zhipu GLM 5.1
LLM_API_URL=https://open.bigmodel.cn/api/coding/paas/v4/chat/completions
LLM_MODEL=glm-5.1
# Set ZHIPU_API_KEY in your environment (Hermes .env)

# FALLBACK: NVIDIA NIM (gratis)
LLM_FALLBACK_URL=https://integrate.api.nvidia.com/v1/chat/completions
LLM_FALLBACK_MODEL=z-ai/glm-5.1
# Set NVIDIA_API_KEY in your environment (Hermes .env)

# Enable LLM extraction (true|false)
LLM_EXTRACTION_ENABLED=true

# Obsidian vault path (for curiosity file output)
OBSIDIAN_VAULT=/path/to/your/Obsidian/Vault

# Server
HOST=127.0.0.1
PORT=8901

# Database
DB_PATH=./muninn_v4.db

# Memory decay
DECAY_RATE=0.95
MIN_CONFIDENCE=0.1
REINFORCE_BOOST=0.1